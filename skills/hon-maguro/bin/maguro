#!/usr/bin/env bash
# Hon Maguro — eval against STANDARDS.md. Binary: pass all or Fail.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="0.17.0"

BAR_P99_MS=300
BAR_QUERY_MS=100
BAR_TTFB_MS=50
BAR_MAX_DEPS=20

die() { echo "error: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

usage() {
  cat <<EOF
maguro v$VERSION — Hon Maguro eval

  maguro init [path]   Drop HON-MAGURO-EVAL.md
  maguro links [path]  Check markdown links (SCORE3; curl only — no install)
  maguro eval [path]   Eval against standards (auto: strict, secrets, deps, links)
  maguro help
EOF
}

as_int() {
  local n="${1:-0}"
  n="$(printf '%s' "$n" | tr -d '[:space:]')"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  echo "$n"
}

rg_count() {
  local pattern="$1" dir="$2"
  shift 2
  local n=0
  if have rg; then
    n="$(rg -n --hidden --glob '!.git/*' --glob '!node_modules/*' --glob '!dist/*' \
      "$@" -e "$pattern" "$dir" 2>/dev/null | wc -l | tr -d '[:space:]' || true)"
  fi
  as_int "$n"
}

find_first() {
  local dir="$1"; shift
  local f
  for f in "$@"; do
    [[ -e "$dir/$f" ]] && { echo "$f"; return 0; }
  done
  return 1
}

find_eval() {
  local dir="$1" f
  for f in HON-MAGURO-EVAL.md docs/HON-MAGURO-EVAL.md; do
    [[ -f "$dir/$f" ]] && { echo "$f"; return 0; }
  done
  return 1
}

# Evidence cell non-empty for | ID | ☐ | evidence |
row_has_evidence() {
  local file="$1" id="$2"
  local line ev
  line="$(grep -E "^\| ${id} " "$file" 2>/dev/null | head -1 || true)"
  [[ -z "$line" ]] && return 1
  ev="$(echo "$line" | awk -F'|' '{gsub(/^ +| +$/,"",$4); print $4}')"
  [[ -n "$ev" && "$ev" != "☐" ]]
}

row() { printf '  %-7s %-5s %s\n' "$1" "$2" "$3"; }

# One-line "how to pass" per bar (printed only on FAIL).
tip_for() {
  case "$1" in
    SPEED1) echo "Measure TTFB on every product URL (localhost, cache-warm); each ≤${BAR_TTFB_MS}ms. Put URL list + ms in EVAL." ;;
    SPEED2) echo "Measure LCP on every product URL (Fast 3G, 4× CPU); each ≤2.0s. Put URL list + seconds in EVAL." ;;
    SPEED3) echo "Measure p99 on every product API route; each ≤${BAR_P99_MS}ms. Put routes + p99 in EVAL." ;;
    SPEED4) echo "Measure every product query; each ≤${BAR_QUERY_MS}ms. Put query names + ms in EVAL." ;;
    SPEED5) echo "Measure main-path JS gzip (named entry); ≤200 KiB or named exception + size. Put KiB in EVAL." ;;
    TEST1)  echo "Full suite exit 0, 3/3 consecutive greens, 0 unbudgeted flakes; list each user-facing flow + ≥1 test." ;;
    SCORE1) echo "Lighthouse Performance median of 3 = 100 (or N/A if no web UI). bin/lighthouse-median <url>." ;;
    SCORE2) echo "React Doctor = 100/100 on each prod React app (or N/A if no React). Fix findings — don't disable rules." ;;
    SCORE3) echo "Fix broken markdown links. Run: maguro links <path> (lists BROKEN targets)." ;;
    DOCS1)  echo "Fresh clone: README alone boots in 1 attempt; every documented command exits 0; undocumented steps = 0." ;;
    CODE1)  echo "List ≥1 business entity; each maps 1:1 to a primary table/type. Put mapping table in EVAL." ;;
    CODE2)  echo "auth entrypoints = 1; data-access style = 1; user-visible 5xx stack/provider leaks = 0. Put counts in EVAL." ;;
    CODE3)  echo "Set \"strict\": true in tsconfig; replace any / as unknown as with unknown + narrowing (hits = 0)." ;;
    REPO1)  echo "Untrack .env (git rm --cached); remove secret-shaped strings from the tree; rotate any real keys that leaked." ;;
    REPO2)  echo "Prod+dev deps ≤${BAR_MAX_DEPS}, or justify each extra with one-line why in EVAL evidence." ;;
    REPO3)  echo "Catch changelog up to user-visible releases (lag = 0), or mark pre-users if none shipped." ;;
    OPS1)   echo "Record peak AND steady load — each a number + unit (e.g. 100 rps peak, 20 rps steady)." ;;
    OPS2)   echo "Record data now AND monthly growth — each a number + unit (e.g. 2 GB now, +200 MB/mo)." ;;
    OPS3)   echo "Exactly 1 sentence: primary dies → what happens (failover / degrade / hard down)." ;;
    OPS4)   echo "Five \$/mo numbers: ceiling, CPU/mem, storage, egress, third-party. Blank line = fail." ;;
    OPS5)   echo "List 1–6 assumptions (more → restart the plan). Put the count + short list in EVAL." ;;
    OPS6)   echo "One clean-room restore success (date + scenario), or N/A if no durable user data." ;;
    *)      echo "See STANDARDS.md for bar $1; evidence must be number/count/binary (MEET.md)." ;;
  esac
}

cmd_init() {
  local dir="${1:-.}"
  mkdir -p "$dir"
  dir="$(cd "$dir" && pwd)"
  local date project
  date="$(date +%Y-%m-%d)"
  project="$(basename "$dir")"

  if [[ ! -f "$dir/HON-MAGURO-EVAL.md" ]]; then
    sed -e "s/^\*\*Project:\*\*.*/**Project:** $project/" \
        -e "s/^\*\*Date:\*\*.*/**Date:** $date/" \
        "$ROOT/EVAL.md" >"$dir/HON-MAGURO-EVAL.md"
    echo "wrote $dir/HON-MAGURO-EVAL.md"
  else
    echo "skip (exists): HON-MAGURO-EVAL.md"
  fi
  echo "fill evidence, then: maguro eval $dir"
}

# Extract ](target) from markdown; print "file<TAB>target"
md_link_pairs() {
  local dir="$1" f target
  while IFS= read -r -d '' f; do
    grep -oE '\]\([^)]+\)' "$f" 2>/dev/null | sed 's/^](//;s/)$//' | while IFS= read -r target; do
      [[ -z "$target" || "$target" == \#* || "$target" == mailto:* ]] && continue
      printf '%s\t%s\n' "$f" "$target"
    done
  done < <(find "$dir" \( -path '*/.git/*' -o -path '*/node_modules/*' -o -path '*/dist/*' \) -prune \
    -o -name '*.md' -print0 2>/dev/null)
}

# Returns broken count on stdout; lists broken on stderr. 0 = pass.
check_links() {
  local dir="$1"
  local broken=0 total=0 code path base target file
  have curl || die "curl required for maguro links (preinstalled on macOS/Linux)"

  while IFS=$'\t' read -r file target; do
    [[ -z "${target:-}" ]] && continue
    total=$((total + 1))
    if [[ "$target" =~ ^https?:// ]]; then
      code="$(curl -sS -o /dev/null -w '%{http_code}' -L --max-time 12 \
        -A 'maguro-links/0.11' "$target" 2>/dev/null || echo 000)"
      if [[ ! "$code" =~ ^[23][0-9][0-9]$ ]]; then
        echo "BROKEN  $code  $target  ($file)" >&2
        broken=$((broken + 1))
      fi
    else
      # strip query/hash for local paths
      path="${target%%[?#]*}"
      [[ -z "$path" ]] && continue
      base="$(dirname "$file")"
      if [[ -e "$base/$path" || -e "$dir/$path" ]]; then
        :
      else
        echo "BROKEN  missing  $target  ($file)" >&2
        broken=$((broken + 1))
      fi
    fi
  done < <(md_link_pairs "$dir" | sort -u)

  echo "links checked=$total broken=$broken" >&2
  echo "$broken"
}

cmd_links() {
  local dir="${1:-.}"
  dir="$(cd "$dir" && pwd)"
  local broken
  broken="$(check_links "$dir")"
  if [[ "$broken" -eq 0 ]]; then
    echo "SCORE3 PASS  broken=0"
    return 0
  fi
  echo "SCORE3 FAIL  broken=$broken"
  return 1
}

cmd_eval() {
  local dir="${1:-.}"
  dir="$(cd "$dir" && pwd)"
  local project cl fail=0 human=0 pass=0
  local -a fail_ids=()
  project="$(basename "$dir")"
  cl="$(find_eval "$dir" || true)"

  mark_fail() {
    local id="$1" note="$2"
    row "$id" FAIL "$note"
    fail=$((fail + 1))
    fail_ids+=("$id")
  }

  echo "Hon Maguro eval v$VERSION"
  echo "project: $project"
  echo "path:    $dir"
  [[ -n "$cl" ]] && echo "eval:    $cl" || echo "eval:    missing — maguro init"
  echo ""
  echo "  id      auto  note"

  # Human-owned (CODE3, REPO1, REPO2, SCORE3 auto below)
  local id
  local human_ids=(SPEED1 SPEED2 SPEED3 SPEED4 SPEED5 TEST1 SCORE1 SCORE2 DOCS1 CODE1 CODE2 REPO3 OPS1 OPS2 OPS3 OPS4 OPS5 OPS6)
  if [[ -z "$cl" ]]; then
    for id in "${human_ids[@]}"; do
      mark_fail "$id" "no eval form — run: maguro init $dir"
    done
  else
    for id in "${human_ids[@]}"; do
      if ! row_has_evidence "$dir/$cl" "$id"; then
        mark_fail "$id" "no evidence — put number/count/binary in EVAL"
        continue
      fi
      local line ms
      line="$(grep -E "^\| ${id} " "$dir/$cl" | head -1)"
      ms="$(echo "$line" | grep -oE '[0-9]+[[:space:]]*ms' | head -1 | grep -oE '[0-9]+' || true)"
      if [[ "$id" == "SPEED3" && -n "$ms" && "$ms" -gt "$BAR_P99_MS" ]]; then
        mark_fail SPEED3 "evidence ${ms}ms > ${BAR_P99_MS}ms"
      elif [[ "$id" == "SPEED4" && -n "$ms" && "$ms" -gt "$BAR_QUERY_MS" ]]; then
        mark_fail SPEED4 "evidence ${ms}ms > ${BAR_QUERY_MS}ms"
      elif [[ "$id" == "SPEED1" && -n "$ms" && "$ms" -gt "$BAR_TTFB_MS" ]]; then
        mark_fail SPEED1 "evidence ${ms}ms > ${BAR_TTFB_MS}ms"
      elif [[ "$id" == "SPEED3" && -n "$ms" ]]; then
        row SPEED3 PASS "p99 ${ms}ms ≤ ${BAR_P99_MS}ms"
        pass=$((pass + 1))
      elif [[ "$id" == "SPEED4" && -n "$ms" ]]; then
        row SPEED4 PASS "query ${ms}ms ≤ ${BAR_QUERY_MS}ms"
        pass=$((pass + 1))
      elif [[ "$id" == "SPEED1" && -n "$ms" ]]; then
        row SPEED1 PASS "TTFB ${ms}ms ≤ ${BAR_TTFB_MS}ms"
        pass=$((pass + 1))
      else
        row "$id" HUMAN "evidence present — confirm vs STANDARDS.md"
        human=$((human + 1))
      fi
    done
  fi

  # SCORE3 auto: markdown links (maguro links)
  local link_broken
  link_broken="$(check_links "$dir" 2>/dev/null || echo 1)"
  link_broken="$(as_int "$link_broken")"
  if [[ "$link_broken" -eq 0 ]]; then
    row SCORE3 PASS "maguro links broken=0"
    pass=$((pass + 1))
  else
    mark_fail SCORE3 "maguro links broken=$link_broken — run: maguro links $dir"
  fi

  # CODE3 auto: strict + any
  local tsconfig any_count
  tsconfig="$(find_first "$dir" tsconfig.json backend/tsconfig.json frontend/tsconfig.json || true)"
  any_count="$(rg_count 'as any|: any\b|as unknown as' "$dir" --glob '*.ts' --glob '*.tsx')"
  if [[ -n "$tsconfig" ]] && grep -qE '"strict"\s*:\s*true' "$dir/$tsconfig" 2>/dev/null; then
    if [[ "$any_count" -gt 0 ]]; then
      mark_fail CODE3 "strict on but ~$any_count any/cast hits"
    else
      row CODE3 PASS "strict: true, no any hits"
      pass=$((pass + 1))
    fi
  elif [[ -n "$tsconfig" ]]; then
    mark_fail CODE3 "strict not true"
  else
    if [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" CODE3; then
      row CODE3 HUMAN "no tsconfig — evidence only"
      human=$((human + 1))
    else
      mark_fail CODE3 "no tsconfig / no evidence"
    fi
  fi

  # REPO1 auto: secrets
  local secret_hits env_tracked=0
  secret_hits="$(rg_count '(api[_-]?key|secret[_-]?key|sk_live|sk_test|ghp_[A-Za-z0-9]{20,})' "$dir" \
    --glob '!.env*' --glob '!*.example' --glob '!*.md')"
  if [[ -d "$dir/.git" ]] && have git; then
    git -C "$dir" ls-files | grep -qE '(^|/)\.env$' && env_tracked=1 || true
  fi
  if [[ "$env_tracked" -eq 1 ]]; then
    mark_fail REPO1 ".env tracked"
  elif [[ "$secret_hits" -gt 0 ]]; then
    mark_fail REPO1 "~$secret_hits secret-shaped hits"
  else
    row REPO1 PASS "no tracked .env / no obvious secrets"
    pass=$((pass + 1))
  fi

  # REPO2 auto: deps
  local dep_count=0
  if [[ -f "$dir/package.json" ]] && have python3; then
    dep_count="$(as_int "$(python3 -c "import json;p=json.load(open('$dir/package.json'));print(len(p.get('dependencies')or{})+len(p.get('devDependencies')or{}))")")"
    if [[ "$dep_count" -le "$BAR_MAX_DEPS" ]]; then
      row REPO2 PASS "$dep_count deps ≤ $BAR_MAX_DEPS"
      pass=$((pass + 1))
    elif [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" REPO2; then
      row REPO2 HUMAN "$dep_count deps — justify extras in evidence"
      human=$((human + 1))
    else
      mark_fail REPO2 "$dep_count deps > $BAR_MAX_DEPS"
    fi
  else
    if [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" REPO2; then
      row REPO2 HUMAN "no package.json — evidence only"
      human=$((human + 1))
    else
      mark_fail REPO2 "no package.json / no evidence"
    fi
  fi

  echo ""
  echo "summary  PASS=$pass  FAIL=$fail  HUMAN=$human"
  local verdict="FAIL"
  if [[ "$fail" -eq 0 && "$human" -eq 0 ]]; then
    verdict="HON MAGURO"
  elif [[ "$fail" -eq 0 ]]; then
    verdict="FAIL (HUMAN open)"
  else
    verdict="FAIL ($fail)"
  fi
  echo "result:  $verdict"

  local tips_block=""
  if [[ "$fail" -gt 0 ]]; then
    echo ""
    echo "how to pass:"
    tips_block=$'\n## How to pass\n'
    local fid
    # unique fail ids, stable order
    local -a seen=()
    for fid in "${fail_ids[@]}"; do
      local already=0 s
      for s in "${seen[@]+"${seen[@]}"}"; do
        [[ "$s" == "$fid" ]] && { already=1; break; }
      done
      [[ "$already" -eq 1 ]] && continue
      seen+=("$fid")
      local tip
      tip="$(tip_for "$fid")"
      printf '  %-7s %s\n' "$fid" "$tip"
      tips_block+="- **${fid}:** ${tip}"$'\n'
    done
    echo ""
    echo "fix product, not meter — MEET.md · full bars — STANDARDS.md"
  fi

  {
    echo "# Hon Maguro eval — $project"
    echo ""
    echo "- **Date:** $(date +%Y-%m-%d)"
    echo "- **Tool:** maguro $VERSION"
    echo "- **Result:** $verdict"
    echo "- **PASS / FAIL / HUMAN:** $pass / $fail / $human"
    if [[ -n "$tips_block" ]]; then
      echo "$tips_block"
    fi
  } >"$dir/HON-MAGURO-EVAL-REPORT.md"
  echo "wrote $dir/HON-MAGURO-EVAL-REPORT.md"
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  init) cmd_init "${1:-.}" ;;
  links) cmd_links "${1:-.}" ;;
  eval) cmd_eval "${1:-.}" ;;
  help|-h|--help) usage ;;
  version|-v|--version) echo "maguro $VERSION" ;;
  bars) echo "see STANDARDS.md (TTFB≤${BAR_TTFB_MS}ms p99≤${BAR_P99_MS}ms query≤${BAR_QUERY_MS}ms deps≤${BAR_MAX_DEPS})" ;;
  *) usage; die "unknown: $cmd" ;;
esac

#!/usr/bin/env bash
# Hon Maguro grader — scorecard helper (auto signals + human leftovers).
# Usage: hm <init|grade|help> [path]
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="0.2.0"

die() { echo "error: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

usage() {
  cat <<'EOF'
hm — Hon Maguro scorecard tool

  hm init [path]    Drop HON-MAGURO-CHECKLIST.md (napkin + build standards)
  hm grade [path]   Auto-scan path; print grade report (default: .)
  hm help           This help

Napkin fields (N1–N15) are standards, not notes.
All N* + B* pass → Hon Maguro. Anything else → Fail.
EOF
}

# --- helpers ---

rg_count() {
  local pattern="$1" dir="$2"
  shift 2
  local n
  if have rg; then
    n="$(rg -n --hidden --glob '!.git/*' --glob '!node_modules/*' --glob '!dist/*' \
      --glob '!.deno/*' --glob '!vendor/*' --glob '!*.lock' \
      "$@" -e "$pattern" "$dir" 2>/dev/null | wc -l | tr -d '[:space:]' || true)"
  else
    n="$(grep -RIn --exclude-dir=.git --exclude-dir=node_modules --exclude-dir=dist \
      --exclude-dir=.deno --exclude-dir=vendor "$@" -E "$pattern" "$dir" 2>/dev/null | wc -l | tr -d '[:space:]' || true)"
  fi
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  echo "$n"
}

as_int() {
  local n="${1:-0}"
  n="$(printf '%s' "$n" | tr -d '[:space:]')"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  echo "$n"
}

find_first() {
  local dir="$1"
  shift
  local f
  for f in "$@"; do
    if [[ -e "$dir/$f" ]]; then
      echo "$f"
      return 0
    fi
  done
  return 1
}

# Scorecard path if present
find_checklist() {
  local dir="$1"
  local f
  for f in HON-MAGURO-CHECKLIST.md docs/HON-MAGURO-CHECKLIST.md; do
    [[ -f "$dir/$f" ]] && { echo "$f"; return 0; }
  done
  return 1
}

# True if checklist cell for id looks filled (not ___ / blank placeholder)
checklist_filled() {
  local file="$1" id="$2"
  # row like: | N1 | ... | value | ☐ |
  local line
  line="$(grep -E "^\| ${id} " "$file" 2>/dev/null | head -1 || true)"
  [[ -z "$line" ]] && return 1
  # fail if still placeholder
  if echo "$line" | grep -qE '___|\$___|☐ \|[[:space:]]*\|$'; then
    return 1
  fi
  # value column roughly non-empty: has digit or $ or word longer than 2 in third cells
  if echo "$line" | grep -qE '[0-9]|\$[0-9A-Za-z]|[A-Za-z]{3,}'; then
    # still reject pure template tails
    if echo "$line" | grep -qE '\| ___ \|'; then
      return 1
    fi
    return 0
  fi
  return 1
}

# --- init ---

cmd_init() {
  local dir="${1:-.}"
  mkdir -p "$dir"
  dir="$(cd "$dir" && pwd)"
  local date project
  date="$(date +%Y-%m-%d)"
  project="$(basename "$dir")"

  if [[ ! -f "$dir/HON-MAGURO-CHECKLIST.md" ]]; then
    sed -e "s/^\*\*Project:\*\*.*/**Project:** $project/" \
        -e "s/^\*\*Date:\*\*.*/**Date:** $date/" \
        "$ROOT/CHECKLIST.md" >"$dir/HON-MAGURO-CHECKLIST.md"
    echo "wrote $dir/HON-MAGURO-CHECKLIST.md"
  else
    echo "skip checklist (exists): HON-MAGURO-CHECKLIST.md"
  fi

  echo "next: fill N1–N15 + B1–B7, then: hm grade $dir"
}

# --- grade ---

row() {
  local id="$1" status="$2" name="$3" evidence="$4"
  printf '  %-4s %-5s %s\n' "$id" "$status" "$name"
  if [[ -n "$evidence" ]]; then
    printf '        %s\n' "$evidence"
  fi
}

cmd_grade() {
  local dir="${1:-.}"
  dir="$(cd "$dir" && pwd)"
  local project
  project="$(basename "$dir")"
  local auto_fail=0 human=0 auto_pass=0

  local cl=""
  cl="$(find_checklist "$dir" || true)"

  echo "Hon Maguro grade v$VERSION"
  echo "project: $project"
  echo "path:    $dir"
  [[ -n "$cl" ]] && echo "card:    $cl" || echo "card:    (missing — run hm init)"
  echo ""
  echo "  id   auto  standard"
  echo "  ---- ----- --------"

  # --- Napkin N1–N15 ---
  if [[ -z "$cl" ]]; then
    local n
    for n in N1 N2 N3 N4 N5 N6 N7 N8 N9 N10 N11 N12 N13 N14 N15; do
      row "$n" FAIL "napkin standard" "no checklist — run: hm init"
      auto_fail=$((auto_fail + 1))
    done
  else
    local n label
    for n in N1 N2 N3 N4 N5 N6 N7 N8 N9 N10 N11 N12 N13 N14 N15; do
      case "$n" in
        N1) label="Peak load (QPS)" ;;
        N2) label="Steady load (QPS/DAU)" ;;
        N3) label="Critical path p99" ;;
        N4) label="Data now → growth" ;;
        N5) label="Failure mode" ;;
        N6) label="Monthly cost ceiling" ;;
        N7) label="Cost: CPU/mem" ;;
        N8) label="Cost: storage" ;;
        N9) label="Cost: egress" ;;
        N10) label="Cost: third-party" ;;
        N11) label="Perf budget: API p99" ;;
        N12) label="Perf budget: query" ;;
        N13) label="Perf budget: client/bundle" ;;
        N14) label="How budgets are checked" ;;
        N15) label="Assumptions (≤6)" ;;
      esac
      if checklist_filled "$dir/$cl" "$n"; then
        # unit sanity for numeric rows
        local line
        line="$(grep -E "^\| ${n} " "$dir/$cl" | head -1)"
        case "$n" in
          N3|N11|N12)
            if echo "$line" | grep -qE '[0-9]+[[:space:]]*ms|[0-9]+ms'; then
              row "$n" PASS "$label" "filled with ms"
              auto_pass=$((auto_pass + 1))
            else
              row "$n" FAIL "$label" "need number + ms"
              auto_fail=$((auto_fail + 1))
            fi
            ;;
          N6|N7|N8|N9|N10)
            if echo "$line" | grep -qE '\$[0-9]'; then
              row "$n" PASS "$label" "filled with \$"
              auto_pass=$((auto_pass + 1))
            else
              row "$n" FAIL "$label" "need \$ amount"
              auto_fail=$((auto_fail + 1))
            fi
            ;;
          N1|N2)
            if echo "$line" | grep -qE '[0-9]+'; then
              row "$n" PASS "$label" "filled"
              auto_pass=$((auto_pass + 1))
            else
              row "$n" FAIL "$label" "need a number"
              auto_fail=$((auto_fail + 1))
            fi
            ;;
          *)
            row "$n" PASS "$label" "filled in checklist"
            auto_pass=$((auto_pass + 1))
            ;;
        esac
      else
        row "$n" FAIL "$label" "blank/placeholder in checklist"
        auto_fail=$((auto_fail + 1))
      fi
    done
  fi

  # --- Build B1–B7 ---
  # B1 schema
  local schema_hit=""
  schema_hit="$(find_first "$dir" \
    schema.sql db/schema.sql sql/schema.sql \
    drizzle.config.ts drizzle.config.js \
    prisma/schema.prisma \
    backend/src/db/schema.ts src/db/schema.ts \
    migrations docs/schema.md 2>/dev/null || true)"
  if [[ -z "$schema_hit" && -d "$dir/migrations" ]]; then schema_hit="migrations/"; fi
  if [[ -n "$schema_hit" ]]; then
    row B1 HUMAN "Domain-first schema" "found $schema_hit — confirm domain names"
    human=$((human + 1))
  else
    row B1 HUMAN "Domain-first schema" "no schema found — N/A only for pure libs"
    human=$((human + 1))
  fi

  row B2 HUMAN "One path per concern" "confirm one auth + one data path"
  human=$((human + 1))

  # B3 strict
  local tsconfig any_count
  tsconfig="$(find_first "$dir" tsconfig.json backend/tsconfig.json frontend/tsconfig.json || true)"
  any_count="$(as_int "$(rg_count 'as any|: any\b|as unknown as' "$dir" --glob '*.ts' --glob '*.tsx' || true)")"
  if [[ -n "$tsconfig" ]] && grep -qE '"strict"\s*:\s*true' "$dir/$tsconfig" 2>/dev/null; then
    if [[ "$any_count" -gt 0 ]]; then
      row B3 FAIL "Strict types at boundaries" "$tsconfig strict but ~$any_count any/cast hits"
      auto_fail=$((auto_fail + 1))
    else
      row B3 HUMAN "Strict types at boundaries" "strict on — confirm runtime validation"
      human=$((human + 1))
    fi
  elif [[ -n "$tsconfig" ]]; then
    row B3 FAIL "Strict types at boundaries" "$tsconfig without strict: true"
    auto_fail=$((auto_fail + 1))
  else
    row B3 HUMAN "Strict types at boundaries" "no tsconfig — confirm boundary validation"
    human=$((human + 1))
  fi

  # B4 secrets
  local secret_hits env_tracked=0
  secret_hits="$(as_int "$(rg_count '(api[_-]?key|secret[_-]?key|private[_-]?key|aws_secret|sk_live|sk_test|ghp_[A-Za-z0-9]{20,}|xox[baprs]-)' "$dir" \
    --glob '!.env*' --glob '!*.example' --glob '!*.md' --glob '!*.svg' || true)")"
  if [[ -d "$dir/.git" ]] && have git; then
    if git -C "$dir" ls-files | grep -qE '(^|/)\.env$'; then env_tracked=1; fi
  fi
  if [[ "$env_tracked" -eq 1 ]]; then
    row B4 FAIL "Secrets never in tree" ".env is tracked by git"
    auto_fail=$((auto_fail + 1))
  elif [[ "$secret_hits" -gt 0 ]]; then
    row B4 FAIL "Secrets never in tree" "~$secret_hits secret-shaped hits"
    auto_fail=$((auto_fail + 1))
  else
    row B4 HUMAN "Secrets never in tree" "no obvious leaks — confirm release audit if shipping"
    human=$((human + 1))
  fi

  # B5 deps
  local dep_count=0
  if [[ -f "$dir/package.json" ]] && have python3; then
    dep_count="$(as_int "$(python3 - <<PY
import json
p=json.load(open("$dir/package.json"))
print(len(p.get("dependencies") or {})+len(p.get("devDependencies") or {}))
PY
)")"
  fi
  if [[ "$dep_count" -gt 80 ]]; then
    row B5 FAIL "Delete is a feature" "$dep_count package.json deps"
    auto_fail=$((auto_fail + 1))
  else
    row B5 HUMAN "Delete is a feature" "${dep_count:-0} deps — still hunt dead code"
    human=$((human + 1))
  fi

  local obs
  obs="$(find_first "$dir" src/lib/errors.ts backend/src/lib/errors.ts src/errors.ts || true)"
  if [[ -n "$obs" ]]; then
    row B6 HUMAN "Observable defaults" "found $obs"
  else
    row B6 HUMAN "Observable defaults" "confirm one error path"
  fi
  human=$((human + 1))

  row B7 HUMAN "No cargo cult" "each heavy dep needs a one-line why"
  human=$((human + 1))

  echo ""
  echo "summary"
  echo "  auto PASS: $auto_pass"
  echo "  auto FAIL: $auto_fail"
  echo "  HUMAN:     $human"
  echo ""

  local verdict="FAIL"
  if [[ "$auto_fail" -eq 0 && "$human" -eq 0 ]]; then
    verdict="HON MAGURO"
  elif [[ "$auto_fail" -eq 0 ]]; then
    verdict="FAIL (HUMAN rows open)"
  else
    verdict="FAIL ($auto_fail auto fail(s))"
  fi

  echo "verdict: $verdict"
  echo "rules:   binary — Hon Maguro or Fail. Napkin fields are standards."

  local out="$dir/HON-MAGURO-REPORT.md"
  {
    echo "# Hon Maguro report — $project"
    echo ""
    echo "- **Date:** $(date +%Y-%m-%d)"
    echo "- **Tool:** hm $VERSION"
    echo "- **Verdict:** $verdict"
    echo "- **Auto PASS / FAIL / HUMAN:** $auto_pass / $auto_fail / $human"
    echo ""
    echo "Napkin standards N1–N15 are first-class. Signals only — not a grade claim."
  } >"$out"
  echo "wrote $out"
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  init)  cmd_init "${1:-.}" ;;
  grade) cmd_grade "${1:-.}" ;;
  help|-h|--help) usage ;;
  version|-v|--version) echo "hm $VERSION" ;;
  *) usage; die "unknown command: $cmd" ;;
esac

#!/usr/bin/env bash
# Hon Maguro — eval against STANDARDS.md. Binary: pass all or Fail.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="0.10.0"

BAR_P99_MS=300
BAR_QUERY_MS=100
BAR_PAGE_MS=50
BAR_MAX_DEPS=40

die() { echo "error: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

usage() {
  cat <<EOF
hm v$VERSION — Hon Maguro eval

  hm init [path]   Drop HON-MAGURO-EVAL.md
  hm eval [path]   Eval against standards (auto: strict, secrets, deps)
  hm help
EOF
}

as_int() {
  local n="${1:-0}"
  n="$(printf '%s' "$n" | tr -d '[:space:]')"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  echo "$n"
}

rg_count() {
  local pattern="$1" dir="$2"
  shift 2
  local n=0
  if have rg; then
    n="$(rg -n --hidden --glob '!.git/*' --glob '!node_modules/*' --glob '!dist/*' \
      "$@" -e "$pattern" "$dir" 2>/dev/null | wc -l | tr -d '[:space:]' || true)"
  fi
  as_int "$n"
}

find_first() {
  local dir="$1"; shift
  local f
  for f in "$@"; do
    [[ -e "$dir/$f" ]] && { echo "$f"; return 0; }
  done
  return 1
}

find_eval() {
  local dir="$1" f
  for f in HON-MAGURO-EVAL.md docs/HON-MAGURO-EVAL.md; do
    [[ -f "$dir/$f" ]] && { echo "$f"; return 0; }
  done
  return 1
}

# Evidence cell non-empty for | ID | ☐ | evidence |
row_has_evidence() {
  local file="$1" id="$2"
  local line ev
  line="$(grep -E "^\| ${id} " "$file" 2>/dev/null | head -1 || true)"
  [[ -z "$line" ]] && return 1
  ev="$(echo "$line" | awk -F'|' '{gsub(/^ +| +$/,"",$4); print $4}')"
  [[ -n "$ev" && "$ev" != "☐" ]]
}

row() { printf '  %-3s %-5s %s\n' "$1" "$2" "$3"; }

cmd_init() {
  local dir="${1:-.}"
  mkdir -p "$dir"
  dir="$(cd "$dir" && pwd)"
  local date project
  date="$(date +%Y-%m-%d)"
  project="$(basename "$dir")"

  if [[ ! -f "$dir/HON-MAGURO-EVAL.md" ]]; then
    sed -e "s/^\*\*Project:\*\*.*/**Project:** $project/" \
        -e "s/^\*\*Date:\*\*.*/**Date:** $date/" \
        "$ROOT/EVAL.md" >"$dir/HON-MAGURO-EVAL.md"
    echo "wrote $dir/HON-MAGURO-EVAL.md"
  else
    echo "skip (exists): HON-MAGURO-EVAL.md"
  fi
  echo "fill evidence, then: hm eval $dir"
}

cmd_eval() {
  local dir="${1:-.}"
  dir="$(cd "$dir" && pwd)"
  local project cl fail=0 human=0 pass=0
  project="$(basename "$dir")"
  cl="$(find_eval "$dir" || true)"

  echo "Hon Maguro eval v$VERSION"
  echo "project: $project"
  echo "path:    $dir"
  [[ -n "$cl" ]] && echo "eval:    $cl" || echo "eval:    missing — hm init"
  echo ""
  echo "  id  auto  note"

  # Human-owned (C3, R1, R2 auto below)
  local id
  local human_ids=(P1 P2 P3 P4 Q1 T1 T2 T3 D1 C1 C2 C4 R3 R4 O1 O2 O3 O4 O5 O6)
  if [[ -z "$cl" ]]; then
    for id in "${human_ids[@]}"; do
      row "$id" FAIL "no eval form"
      fail=$((fail + 1))
    done
  else
    for id in "${human_ids[@]}"; do
      if ! row_has_evidence "$dir/$cl" "$id"; then
        row "$id" FAIL "no evidence"
        fail=$((fail + 1))
        continue
      fi
      local line ms
      line="$(grep -E "^\| ${id} " "$dir/$cl" | head -1)"
      ms="$(echo "$line" | grep -oE '[0-9]+[[:space:]]*ms' | head -1 | grep -oE '[0-9]+' || true)"
      if [[ "$id" == "P2" && -n "$ms" && "$ms" -gt "$BAR_P99_MS" ]]; then
        row P2 FAIL "evidence ${ms}ms > ${BAR_P99_MS}ms"
        fail=$((fail + 1))
      elif [[ "$id" == "P3" && -n "$ms" && "$ms" -gt "$BAR_QUERY_MS" ]]; then
        row P3 FAIL "evidence ${ms}ms > ${BAR_QUERY_MS}ms"
        fail=$((fail + 1))
      elif [[ "$id" == "P1" && -n "$ms" && "$ms" -gt "$BAR_PAGE_MS" ]]; then
        row P1 FAIL "evidence ${ms}ms > ${BAR_PAGE_MS}ms"
        fail=$((fail + 1))
      elif [[ "$id" == "P2" && -n "$ms" ]]; then
        row P2 PASS "p99 ${ms}ms ≤ ${BAR_P99_MS}ms"
        pass=$((pass + 1))
      elif [[ "$id" == "P3" && -n "$ms" ]]; then
        row P3 PASS "query ${ms}ms ≤ ${BAR_QUERY_MS}ms"
        pass=$((pass + 1))
      elif [[ "$id" == "P1" && -n "$ms" ]]; then
        row P1 PASS "page ${ms}ms ≤ ${BAR_PAGE_MS}ms"
        pass=$((pass + 1))
      else
        row "$id" HUMAN "evidence present — confirm vs STANDARDS.md"
        human=$((human + 1))
      fi
    done
  fi

  # C3 auto: strict + any
  local tsconfig any_count
  tsconfig="$(find_first "$dir" tsconfig.json backend/tsconfig.json frontend/tsconfig.json || true)"
  any_count="$(rg_count 'as any|: any\b|as unknown as' "$dir" --glob '*.ts' --glob '*.tsx')"
  if [[ -n "$tsconfig" ]] && grep -qE '"strict"\s*:\s*true' "$dir/$tsconfig" 2>/dev/null; then
    if [[ "$any_count" -gt 0 ]]; then
      row C3 FAIL "strict on but ~$any_count any/cast hits"
      fail=$((fail + 1))
    else
      row C3 PASS "strict: true, no any hits"
      pass=$((pass + 1))
    fi
  elif [[ -n "$tsconfig" ]]; then
    row C3 FAIL "strict not true"
    fail=$((fail + 1))
  else
    if [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" C3; then
      row C3 HUMAN "no tsconfig — evidence only"
      human=$((human + 1))
    else
      row C3 FAIL "no tsconfig / no evidence"
      fail=$((fail + 1))
    fi
  fi

  # R1 auto: secrets
  local secret_hits env_tracked=0
  secret_hits="$(rg_count '(api[_-]?key|secret[_-]?key|sk_live|sk_test|ghp_[A-Za-z0-9]{20,})' "$dir" \
    --glob '!.env*' --glob '!*.example' --glob '!*.md')"
  if [[ -d "$dir/.git" ]] && have git; then
    git -C "$dir" ls-files | grep -qE '(^|/)\.env$' && env_tracked=1 || true
  fi
  if [[ "$env_tracked" -eq 1 ]]; then
    row R1 FAIL ".env tracked"
    fail=$((fail + 1))
  elif [[ "$secret_hits" -gt 0 ]]; then
    row R1 FAIL "~$secret_hits secret-shaped hits"
    fail=$((fail + 1))
  else
    row R1 PASS "no tracked .env / no obvious secrets"
    pass=$((pass + 1))
  fi

  # R2 auto: deps
  local dep_count=0
  if [[ -f "$dir/package.json" ]] && have python3; then
    dep_count="$(as_int "$(python3 -c "import json;p=json.load(open('$dir/package.json'));print(len(p.get('dependencies')or{})+len(p.get('devDependencies')or{}))")")"
    if [[ "$dep_count" -le "$BAR_MAX_DEPS" ]]; then
      row R2 PASS "$dep_count deps ≤ $BAR_MAX_DEPS"
      pass=$((pass + 1))
    elif [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" R2; then
      row R2 HUMAN "$dep_count deps — justify extras in evidence"
      human=$((human + 1))
    else
      row R2 FAIL "$dep_count deps > $BAR_MAX_DEPS"
      fail=$((fail + 1))
    fi
  else
    if [[ -n "$cl" ]] && row_has_evidence "$dir/$cl" R2; then
      row R2 HUMAN "no package.json — evidence only"
      human=$((human + 1))
    else
      row R2 FAIL "no package.json / no evidence"
      fail=$((fail + 1))
    fi
  fi

  echo ""
  echo "summary  PASS=$pass  FAIL=$fail  HUMAN=$human"
  local verdict="FAIL"
  if [[ "$fail" -eq 0 && "$human" -eq 0 ]]; then
    verdict="HON MAGURO"
  elif [[ "$fail" -eq 0 ]]; then
    verdict="FAIL (HUMAN open)"
  else
    verdict="FAIL ($fail)"
  fi
  echo "result:  $verdict"

  {
    echo "# Hon Maguro eval — $project"
    echo ""
    echo "- **Date:** $(date +%Y-%m-%d)"
    echo "- **Tool:** hm $VERSION"
    echo "- **Result:** $verdict"
    echo "- **PASS / FAIL / HUMAN:** $pass / $fail / $human"
  } >"$dir/HON-MAGURO-EVAL-REPORT.md"
  echo "wrote $dir/HON-MAGURO-EVAL-REPORT.md"
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  init) cmd_init "${1:-.}" ;;
  eval) cmd_eval "${1:-.}" ;;
  help|-h|--help) usage ;;
  version|-v|--version) echo "hm $VERSION" ;;
  bars) echo "see STANDARDS.md (p99≤${BAR_P99_MS}ms query≤${BAR_QUERY_MS}ms page≤${BAR_PAGE_MS}ms deps≤${BAR_MAX_DEPS})" ;;
  *) usage; die "unknown: $cmd" ;;
esac
